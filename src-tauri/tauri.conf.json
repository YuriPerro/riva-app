{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Riva",
  "version": "0.3.0",
  "identifier": "com.yuribaumgartner.riva",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Riva",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxNDNFM0RGNDAwQjg4OEEKUldTS2lBdEEzK05Ea2YrWmVTYTZqQ1llNUJhUDdRMDJTcDJBWDFSd1hoOHNmREtoZGtxVGVZekEK",
      "endpoints": ["https://riva-updater.vercel.app/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["sounds/notification.aiff"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
